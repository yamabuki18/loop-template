# Secrets — PLAINTEXT scoped env files (secret.<scope>.env). This gitignore is the only thing
# between them and an accidental commit: never remove these lines.
secret.*.env
control/secret.*.env
secret.env
control/secret.env

# Per-deployment hints / runtime state (recreated by setup.sh / the loop).
control/.source-repo
.source-repo
.loop-workspace
state/
worktrees/
canonical/
review/
