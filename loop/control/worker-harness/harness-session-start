#!/usr/bin/env bash
# SessionStart — inject the worker's current assignment straight into the session context, so a
# freshly (re)started worker Claude knows its task WITHOUT relying on a herdr send-text nudge
# (nudges are best-effort and can be dropped while the worker is mid-input). This is the
# "delivery as a guarantee, not a hope" companion to the stop-gate feedback check (A2).
#
# Claude Code reads a SessionStart hook's stdout JSON and merges hookSpecificOutput.additionalContext
# into the session. We surface the task brief and, if present, any unaddressed supervisor feedback.
# HARNESS_DIR is the worker's out-of-tree state dir (set by spawn via the pane env); without it
# there is nothing to inject (e.g. a human session outside the loop) — emit nothing.
hdir="${HARNESS_DIR:-}"
[ -n "$hdir" ] || exit 0
task_file="$hdir/task.md"
fb_file="$hdir/feedback.md"

ctx=""
[ -f "$task_file" ] && ctx+="$(cat "$task_file")"$'\n\n'
if [ -f "$fb_file" ]; then
  ctx+="## Outstanding supervisor feedback (acceptance tests failed)"$'\n'
  ctx+="$(cat "$fb_file")"$'\n'
fi

# Nothing to inject -> emit nothing (valid: no additional context).
[ -n "$ctx" ] || exit 0

# Emit JSON safely. Prefer jq; fall back to a python one-liner only if jq is unavailable.
if command -v jq >/dev/null 2>&1; then
  jq -nc --arg c "$ctx" \
    '{hookSpecificOutput:{hookEventName:"SessionStart",additionalContext:$c}}'
else
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":%s}}' \
    "$(printf '%s' "$ctx" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')"
fi
exit 0
