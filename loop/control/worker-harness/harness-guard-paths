#!/usr/bin/env bash
# PreToolUse(Edit/Write) — two structural rules, both fire on every edit:
#  (1) PROTECTED paths are supervisor-owned: workers can NEVER edit them, regardless of their
#      assigned domain. Set via PROTECTED_PATHS env (default "tests/"). This makes "tests are
#      the supervisor's spec" an absolute invariant, independent of each assign.sh.
#  (2) Otherwise the worker may only edit inside its declared ownership domain (path PREFIXES
#      in /work/.harness/owned-paths, set by ./control/assign.sh).
input="$(cat)"
# D10: also pick up NotebookEdit's notebook_path so notebook edits go through this guard too.
path="$(printf '%s' "$input" | jq -r '.tool_input.file_path // .tool_input.path // .tool_input.notebook_path // empty' 2>/dev/null)"
[ -n "$path" ] || exit 0

# D5.3: normalize before matching so tricks like /work/./tests/x or /work/../work/tests/x
# cannot slip past the prefix check. realpath -m resolves . and .. without requiring the file
# to exist (edits create new files). Relative paths are resolved against /work.
case "$path" in
  /*) abs="$(realpath -m "$path" 2>/dev/null || echo "$path")" ;;
  *)  abs="$(realpath -m "/work/$path" 2>/dev/null || echo "/work/$path")" ;;
esac
rel="${abs#/work/}"

# Always-allowed housekeeping.
case "$rel" in
  STATUS|.harness/*) exit 0 ;;
esac

# (1) Unconditional protected paths (supervisor-owned). Default: tests/
protected="${PROTECTED_PATHS:-tests/}"
for p in $protected; do
  [ -n "$p" ] || continue
  case "$rel" in
    "$p"*)
      echo "HARNESS: '$rel' is under a supervisor-owned protected path ($p). Workers cannot edit the test/spec tree; write co-located unit tests inside your own src area instead, or ask the supervisor." >&2
      exit 2 ;;
  esac
done

# (2) Ownership domain. No domain declared yet -> no further restriction.
# (HARNESS_OWNED_PATHS override exists only so the toolkit's unit tests can point at a temp file;
#  in the container it is unset and defaults to the real path — production behavior unchanged.)
owned="${HARNESS_OWNED_PATHS:-/work/.harness/owned-paths}"
[ -f "$owned" ] || exit 0
while IFS= read -r prefix; do
  [ -n "$prefix" ] || continue
  case "$rel" in
    "$prefix"*) exit 0 ;;
  esac
done < "$owned"

echo "HARNESS: '$rel' is outside this worker's ownership domain [$(tr '\n' ' ' < "$owned")]. Edit only your assigned paths; ask the supervisor to reassign if you truly need this file." >&2
exit 2
