#!/usr/bin/env bash
# PreToolUse(Bash + Read/Edit/Write/Grep/Glob/NotebookEdit) — secret concealment, MANDATORY for
# v3 host-mode workers. In v2 the Docker wall (L3) kept host secrets physically unreachable;
# on the host the wall is gone, so this hook is the L2 fence: it blocks the obvious ways a
# worker could read key material (age keys, sops files, host logins, SSH) or dump credentials
# from its environment. Best-effort by nature (a determined agent has side channels — README
# states this honestly); the hard guarantees remain the gate + "gate/codex secrets never enter
# any Claude process". Exit 2 blocks the tool; stderr is shown to Claude.
# Fail closed: this guard needs jq to parse the tool call and realpath (or a python3 fallback)
# to normalize paths. If either is missing the checks below would silently pass through, so we
# deny instead (spawn.sh preflights both).
command -v jq >/dev/null 2>&1 || { echo "HARNESS: jq is required by the worker harness but was not found — refusing the tool (fail-closed)." >&2; exit 2; }
command -v realpath >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1 \
  || { echo "HARNESS: realpath/python3 is required to normalize paths but neither was found — refusing the tool (fail-closed)." >&2; exit 2; }
input="$(cat)"
cmd="$(printf '%s'  "$input" | jq -r '.tool_input.command // empty' 2>/dev/null)"
path="$(printf '%s' "$input" | jq -r '.tool_input.file_path // .tool_input.path // .tool_input.notebook_path // empty' 2>/dev/null)"

deny() { echo "HARNESS: $1" >&2; exit 2; }
# Normalize a path, resolving . and .. WITHOUT requiring the file to exist. realpath first; a
# python3 fallback covers hosts without GNU realpath. Never falls back to the raw string (the
# old fail-open that weakened the ../ defense) — the preflight above guarantees one exists.
norm() { realpath -m "$1" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$1" 2>/dev/null; }

# 1) File-path tools (Read/Edit/Write/Grep/Glob/NotebookEdit): deny key material and credential
#    stores. Normalize first so ../ tricks cannot slip past (same posture as guard-paths D5.3).
if [ -n "$path" ]; then
  abs="$(norm "$path")"
  case "$abs" in
    */sops/age/*|*/age/keys.txt) deny "age key material is off-limits." ;;
    *secret.*env|*.sops.env)     deny "secret env files (even encrypted) are off-limits." ;;
    "$HOME"/.claude|"$HOME"/.claude/*|"$HOME"/.claude.json*) deny "the host Claude config/credentials are off-limits." ;;
    "$HOME"/.codex|"$HOME"/.codex/*)   deny "the host codex auth is off-limits." ;;
    "$HOME"/.ssh|"$HOME"/.ssh/*)       deny "SSH keys are off-limits." ;;
    "$HOME"/.aws/credentials|"$HOME"/.netrc) deny "host credential stores are off-limits." ;;
    /proc/*/environ)             deny "process environments may contain credentials — off-limits." ;;
  esac
  if [ -n "${SOPS_AGE_KEY_FILE:-}" ] && [ "$abs" = "$SOPS_AGE_KEY_FILE" ]; then
    deny "the age key file is off-limits."
  fi
fi

# 2) Bash commands.
[ -n "$cmd" ] || exit 0

# Secret tooling in command position (start / after ;|&| / $( ) — not as a mere argument word.
if echo "$cmd" | grep -qE '(^|[;&|][[:space:]]*|\$\()[[:space:]]*(sops|age|age-keygen|op)([[:space:]]|$)'; then
  deny "invoking the secret tooling (sops/age/op) is supervisor-only."
fi
# Any reference to secret env files or key-material paths.
if echo "$cmd" | grep -qE 'secret\.([A-Za-z0-9_-]+\.)*env|\.sops\.env|\.config/sops|SOPS_AGE_KEY|age/keys\.txt'; then
  deny "secret files / age key paths are off-limits."
fi
if echo "$cmd" | grep -qE '(^|[^A-Za-z0-9_])\.claude(\.json|/)|\.codex/|\.ssh/|(^|[^A-Za-z0-9_])\.netrc|\.aws/credentials'; then
  deny "host credential stores (~/.claude, ~/.codex, ~/.ssh, ~/.netrc, ~/.aws) are off-limits."
fi
if echo "$cmd" | grep -qE '/proc/[0-9a-z]+/environ'; then
  deny "reading process environments is blocked (they can contain credentials)."
fi
# Bare environment dumps. `env VAR=x cmd` and `set -e` remain legal (they take arguments);
# only the argument-less dump forms are blocked.
if echo "$cmd" | grep -qE '(^|[;&|][[:space:]]*)(env|printenv)[[:space:]]*($|[;&|>])'; then
  deny "dumping the environment is blocked (your env contains the worker credential)."
fi
if echo "$cmd" | grep -qE '(^|[;&|][[:space:]]*)set[[:space:]]*($|[;&|>])'; then
  deny "bare 'set' dumps shell variables (may include credentials) — blocked."
fi
if echo "$cmd" | grep -qE '\bexport[[:space:]]+-p\b|\bdeclare[[:space:]]+-x[[:space:]]*($|[;&|>])'; then
  deny "exported-variable dumps are blocked."
fi
# Direct references to credential variable names (echo "$ANTHROPIC_API_KEY" etc.).
if echo "$cmd" | grep -qE 'ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN|OPENAI_API_KEY|CODEX_API_KEY'; then
  deny "referencing credential variables is blocked."
fi
exit 0
