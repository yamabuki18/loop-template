{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "/usr/local/bin/harness-session-start" }] }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "/usr/local/bin/harness-guard-git" }]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [{ "type": "command", "command": "/usr/local/bin/harness-guard-paths" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "/usr/local/bin/harness-autopush" }]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "/usr/local/bin/harness-stop-gate" }] }
    ]
  }
}
