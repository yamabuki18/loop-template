#!/usr/bin/env bash
# PostToolUse(Bash) — after a git commit, publish the branch so the acceptance gate (which
# tests pushed state) always sees the latest work. Non-blocking; stderr is fed back to Claude.
input="$(cat)"
cmd="$(printf '%s' "$input" | jq -r '.tool_input.command // empty' 2>/dev/null)"
echo "$cmd" | grep -qE '\bgit[[:space:]]+commit\b' || exit 0

cd /work 2>/dev/null || exit 0
[ -d .git ] || exit 0

if git push -q origin HEAD 2>/dev/null; then
  echo "harness: auto-pushed $(git rev-parse --abbrev-ref HEAD 2>/dev/null) to origin (gate now sees it)." >&2
else
  echo "harness: auto-push failed — run 'git push origin HEAD' so the gate tests your latest commit." >&2
fi
exit 0
