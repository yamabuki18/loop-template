#!/usr/bin/env bash
# PreToolUse(Bash) — absolute rule, fires every time regardless of context.
# Integration verbs (merge/rebase/cherry-pick) and protected-branch pushes are
# reserved for the supervisor. Exit 2 blocks the tool; stderr is shown to Claude.
input="$(cat)"
cmd="$(printf '%s' "$input" | jq -r '.tool_input.command // empty' 2>/dev/null)"
[ -n "$cmd" ] || exit 0

deny() { echo "HARNESS: $1" >&2; exit 2; }

if echo "$cmd" | grep -qE '\bgit[[:space:]]+(merge|rebase|cherry-pick)\b'; then
  deny "merge/rebase/cherry-pick are supervisor-only. Push your work/ branch with: git push origin HEAD"
fi
# D6: `git pull` = fetch + merge, so it can create the merge commits we forbid above. Block it
# (plain `git fetch` stays allowed — it never integrates).
if echo "$cmd" | grep -qE '\bgit[[:space:]]+pull\b'; then
  deny "git pull integrates (fetch+merge), which is supervisor-only. Use: git fetch origin"
fi
if echo "$cmd" | grep -qE '\bgit[[:space:]]+reset[[:space:]]+--hard\b'; then
  deny "git reset --hard is blocked. Commit or stash instead."
fi
# D6: only treat a protected branch as the PUSH TARGET (refspec), not anywhere in the command,
# so `git push origin work/main-page` is not mis-blocked by a bare \bmain\b match.
if echo "$cmd" | grep -qE '\bgit[[:space:]]+push\b.*[[:space:]:](main|master|develop)([[:space:]]|$)'; then
  deny "pushing to a protected branch is supervisor-only. Use: git push origin HEAD"
fi
if echo "$cmd" | grep -qE '\bgit[[:space:]]+push\b.*(--force|--force-with-lease|[[:space:]]-f\b)'; then
  deny "force-push is blocked."
fi
exit 0
