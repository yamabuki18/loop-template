#!/usr/bin/env bash
# PreToolUse(Bash) — absolute rules, fire every time regardless of context.
# v3 workers share canonical's object store and refs through a git worktree, so besides the
# v2 integration verbs (merge/rebase/cherry-pick), everything that could mutate SHARED git
# state — pushes (canonical's origin is the real project repo!), ref surgery, worktree
# management, gc, repo config — is reserved for the supervisor.
# Exit 2 blocks the tool; stderr is shown to Claude.
# Fail closed: this guard depends on jq to read the tool call. Without jq every `jq -r … //
# empty` yields "" and the `[ -n "$cmd" ] || exit 0` below short-circuits to ALLOW — silently
# disarming the whole client harness on a jq-less host. Deny instead (spawn.sh preflights jq).
command -v jq >/dev/null 2>&1 || { echo "HARNESS: jq is required by the worker harness but was not found — refusing the tool (fail-closed)." >&2; exit 2; }
input="$(cat)"
cmd="$(printf '%s' "$input" | jq -r '.tool_input.command // empty' 2>/dev/null)"
[ -n "$cmd" ] || exit 0

deny() { echo "HARNESS: $1" >&2; exit 2; }

# Match `git` even when the dangerous verb is not ADJACENT to it: git's GLOBAL options can sit
# between `git` and the subcommand, so `git -C /path push` slips past a bare `git[[:space:]]+push`.
# $gpfx = `git` followed by any run of global options, value-taking (-C/-c/--git-dir/--work-tree/
# --namespace) or flag-only (--bare/--no-pager/--paginate/-p), up to the verb. Env prefixes like
# `GIT_DIR=… git push` are already covered (the `git push` substring still matches). This is an
# L2 speed-bump; the HARD push guarantee is the blanked origin push url (setup.sh D12).
gpfx='git([[:space:]]+(-C[[:space:]]+[^[:space:]]+|-c[[:space:]]+[^[:space:]]+|--git-dir(=|[[:space:]]+)[^[:space:]]+|--work-tree(=|[[:space:]]+)[^[:space:]]+|--namespace(=|[[:space:]]+)[^[:space:]]+|--bare|--no-pager|--paginate|-p))*[[:space:]]+'

if echo "$cmd" | grep -qE "\\b${gpfx}(merge|rebase|cherry-pick)\\b"; then
  deny "merge/rebase/cherry-pick are supervisor-only. Commit on your branch; the supervisor integrates."
fi
# D6: `git pull` = fetch + merge, so it can create the merge commits we forbid above. Block it
# (plain `git fetch` stays allowed — it never integrates).
if echo "$cmd" | grep -qE "\\b${gpfx}pull\\b"; then
  deny "git pull integrates (fetch+merge), which is supervisor-only. Use: git fetch origin"
fi
if echo "$cmd" | grep -qE "\\b${gpfx}reset[[:space:]]+--hard\\b"; then
  deny "git reset --hard is blocked. Commit or stash instead."
fi
# v3: ALL pushes are blocked. Your worktree shares refs with canonical — your commit is already
# visible to the supervisor the moment you make it, and canonical's `origin` is the operator's
# real project repo, which a worker must never write.
if echo "$cmd" | grep -qE "\\b${gpfx}push\\b"; then
  deny "git push is blocked in v3: your commits are instantly visible to the supervisor (shared worktree refs) and the remote is the operator's real repo. Just commit."
fi
# Shared-repo protection: worktree surgery, ref surgery, and history/object destruction would
# affect EVERY worker (and canonical itself), not just this box.
if echo "$cmd" | grep -qE "\\b${gpfx}worktree\\b"; then
  deny "git worktree management is supervisor-only (your worktree is created/removed by the loop)."
fi
if echo "$cmd" | grep -qE "\\b${gpfx}(update-ref|symbolic-ref)\\b"; then
  deny "direct ref surgery is blocked — refs are shared with canonical and the other workers."
fi
if echo "$cmd" | grep -qE "\\b${gpfx}(gc|prune)\\b|\\b${gpfx}reflog[[:space:]]+expire\\b"; then
  deny "gc/prune/reflog-expire are blocked — the object store is shared; destroying loose objects could destroy other workers' commits."
fi
# `git branch` mutations against other branches: force-move/force-delete/rename can retarget a
# shared branch (e.g. `git branch -f main X`). Reads and plain creation stay allowed.
if echo "$cmd" | grep -qE "\\b${gpfx}branch\\b.*([[:space:]]-(f|D|M|m)\\b|--force\\b|--delete\\b|--move\\b)"; then
  deny "force/delete/rename of branches is blocked — branches are shared with canonical. Work on your own work/ branch."
fi
# Repo config is SHARED across worktrees, and --global writes the HOST user's ~/.gitconfig.
# Reads are fine; your identity comes from GIT_AUTHOR_*/GIT_COMMITTER_* env (set at spawn).
if echo "$cmd" | grep -qE "\\b${gpfx}config\\b" \
   && ! echo "$cmd" | grep -qE '(--get\b|--get-all\b|--get-regexp\b|--list\b|[[:space:]]-l\b)'; then
  deny "git config writes are blocked (repo config is shared across worktrees; --global is the host user's). Your identity is preset via GIT_AUTHOR_*/GIT_COMMITTER_* env."
fi
exit 0
