# Edit these. Safe to commit (no secrets here).
PROJECT_NAME=myproject       # used to namespace containers/volumes/tmux session
IMAGE=claude-worker:latest   # worker image tag
WORKER_COUNT=3               # how many workers `up.sh` brings online
BASE_BRANCH=main             # branch workers fork from

# Acceptance gate (land.sh). Leave empty to auto-resolve: repo's harness/check.sh, else
# npm ci && npm test if package.json exists, else advisory pass. Set this to override, e.g.
#   CHECK_CMD="npm ci && npm run typecheck && npm test"
CHECK_CMD=

# Gate speed: reuse a persistent package-manager download cache across gate runs
# (node_modules etc. stay clean per run; only downloads are cached). 1=on, 0=off.
GATE_CACHE=1

# Paths the workers may NEVER edit (supervisor-owned), space-separated prefixes. The harness
# enforces this regardless of a worker's assigned domain. Default: the test/spec tree.
PROTECTED_PATHS=tests/

# Pin the Claude Code CLI version baked into the worker image (reproducibility). Empty=latest.
# Used as a --build-arg by setup.sh/update flows. Auto-update is disabled inside the image.
CLAUDE_CODE_VERSION=

# ─── Autonomous loop knobs (loop.sh / watch.sh / plan.sh) ──────────────────────────────────
# How many FAIL→fix rounds a single slice may take before the loop gives up and escalates it
# to a human (writes ESCALATED to memory/PROGRESS.md, stops re-nudging). Prevents infinite burn.
MAX_FEEDBACK_ROUNDS=4
# Safety cap on total loop cycles (a DISCOVER→...→ITERATE sweep). 0 = unlimited (until backlog
# empty and all workers idle). Set a number while you trust the loop less.
LOOP_MAX_CYCLES=0
# Max gate containers running at once (watch.sh / loop.sh). Protects host resources.
GATE_CONCURRENCY=2
# Seconds between loop.sh cycles when it is idle-waiting for workers/pushes.
LOOP_POLL_SECS=5
# After landing a slice, auto-rebase the OTHER live workers onto the new base? 1=on.
AUTO_SYNC=1

# Planner (DISCOVER/PLAN). The planner is a HEADLESS, throwaway Claude container that reads
# skills/ + memory/ + a read-only copy of the code and decomposes the next backlog goal into
# vertical slices + thin contract tests. Set to 0 to run the loop with human-written slices only
# (write slice specs into memory/slices/ yourself; see README).
PLANNER_ENABLED=1
# Max slices the planner may emit per goal (= max workers it can fan a single goal across).
PLANNER_MAX_SLICES=3

# Desktop/terminal notifications on loop events (push/gate/land/escalate). 1=on.
# Uses tmux display-message + terminal bell; on WSL2 also wsl-notify-send if installed.
NOTIFY=1

# ─── Secret broker & dev-secret concealment (control/broker.sh) ─────────────────────────────
# The broker is a host-side reverse proxy that HOLDS dev API credentials and injects them into
# outbound calls, so the worker Claude can USE an API without ever READING its token. Workers
# reach it at $BROKER_URL/<alias>/...  Configure aliases in control/secret.broker.env.
BROKER_PORT=8080
# Worker egress policy:
#   open        : workers have normal internet AND can reach the broker (default).
#   broker-only : workers are on an INTERNAL docker network and can reach NOTHING but the broker
#                 — strongest concealment (a leaked-into-context secret still can't be exfiltrated
#                 because there is no route out except through the broker). Requires broker.sh up.
WORKER_EGRESS=open
