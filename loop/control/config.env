# Edit these. Safe to commit (no secrets here).
PROJECT_NAME=myproject       # namespaces the herdr workspace / notifications
WORKER_COUNT=3               # how many workers `up.sh` brings online
BASE_BRANCH=main             # branch workers fork from

# Acceptance gate (land.sh). Leave empty to auto-resolve: repo's harness/check.sh, else
# npm ci && npm test if package.json exists, else advisory pass. Set this to override, e.g.
#   CHECK_CMD="npm ci && npm run typecheck && npm test"
CHECK_CMD=

# Paths the workers may NEVER edit (supervisor-owned), space-separated prefixes. The harness
# enforces this regardless of a worker's assigned domain. Default: the test/spec tree.
# Keeping a typed design SSOT in-repo (e.g. atlas/)? Add it here — design changes belong to
# the design flow, not to implementation workers.
PROTECTED_PATHS=tests/
# Additionally deny worker edits to harness/ (the gate's own check scripts run FROM THE MERGED
# TREE — a worker editing harness/check.sh would neuter its own gate). Security-class guard;
# keep it on. 1=on.
GATE_PROTECT_HARNESS=1
# Test-gaming monitor: scan each gated diff for verifier-weakening patterns (skipped/disabled
# tests added, `|| true` added to check scripts). off | warn (log only, default) | block (gate
# fails with exit 6). Heuristic — run in warn until tuned for your project, then promote.
GATE_TESTGAMING=warn
# F2P preflight (plan.sh): command that runs ONE test file (appended as its last argument),
# e.g. "npx vitest run" or "pytest". When set, the planner's new contract tests are executed
# against the CURRENT base before being committed and must FAIL there (F2P = fail-to-pass; a
# test that already passes specifies nothing). Empty = off — requires that your project can
# run a single test file in isolation.
F2P_CHECK_CMD=

# ─── Model routing (cheap parallel implementers, strong planning/supervision) ────────────────
# Passed as `claude --model <value>`; aliases (sonnet/opus/haiku) or full model names both work.
# Empty = the claude CLI's default for that session.
# Workers are many and run in parallel — route them to a cheaper/faster model.
WORKER_MODEL=sonnet
# The planner decomposes goals and authors the contract tests — give it a strong model
# (empty = CLI default, typically your strongest available).
PLANNER_MODEL=
# The interactive supervisor Claude launched by `loop supervise` (dialogue with the human:
# decompose, assign, verify, land). Strong model recommended.
SUPERVISOR_MODEL=opus

# ─── Secrets (control/secrets.sh, lib.sh secret_exec) ───────────────────────────────────────
# Backend for the scoped secret files (worker/gate/codex):
#   sops  : sops + age (default) — free, no account, encrypted at rest; `loop secrets init/edit`
#   op    : 1Password CLI — secret.<scope>.op.env files consumed via `op run`
#   plain : legacy cleartext env files (doctor warns loudly; migrate: loop secrets migrate --yes)
SECRET_BACKEND=sops
# Where the age private key lives (sops backend). BACK THIS FILE UP.
#SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt

# ─── Autonomous loop knobs (loop.sh / watch.sh / plan.sh) ──────────────────────────────────
# How many FAIL→fix rounds a single slice may take before the loop gives up and escalates it
# to a human (writes ESCALATED to memory/PROGRESS.md, stops re-nudging). Prevents infinite burn.
MAX_FEEDBACK_ROUNDS=4
# Safety cap on total loop ITERATIONS. ⚠️ A "cycle" here is ONE pass of loop.sh's poll loop
# (~LOOP_POLL_SECS apart), NOT one goal. While a worker is implementing/being gated the loop keeps
# polling, so a small value (e.g. 12) stops the loop within ~a minute — BEFORE the worker even
# commits — and nothing lands. Token burn comes from the planner+workers, not from polling, so this
# is NOT the right cost guard: use MAX_FEEDBACK_ROUNDS (per-slice) for that. Leave 0 = unlimited
# (run until backlog empty and all workers idle). Only set a (large) number as a hard backstop.
LOOP_MAX_CYCLES=0
# Per-goal planner timeout (seconds). plan.sh kills the headless planner Claude if it hangs past
# this, so a stuck planner can't block the whole loop. Empty -> plan.sh default (900).
PLAN_TIMEOUT=
# Max concurrent gate runs (watch.sh). Protects host resources.
GATE_CONCURRENCY=2
# Seconds between loop.sh cycles when it is idle-waiting for workers/commits.
LOOP_POLL_SECS=5
# After landing a slice, auto-rebase the OTHER live workers onto the new base? 1=on.
AUTO_SYNC=1
# Anti-corruption fallback for sync when herdr can't report a worker's state (server down /
# crashed pane): rather than rebase a possibly-live worktree, defer unless it has been quiet (no
# new commit) for at least this many seconds. 0 = off (rebase any non-'working' worker).
SYNC_IDLE_SECS=120
# Archive each worker's Claude session transcript(s) to state/logs/<task>.session/ on reap/
# respawn (best-effort). Workers run in an interactive TUI with no --output-format capture, so
# this is the only way to reconstruct a stalled/derailed worker's reasoning after the fact. 1=on.
LOOP_WORKER_TRANSCRIPT=0
# Worker completion signal = new commits AND herdr agent state idle. When herdr can't report a
# state (server down, crashed pane), force the gate anyway after this many poll cycles so
# committed work is never stranded.
AGENT_UNKNOWN_GRACE=6
# ─── Subscription usage guard (Claude plan windows are SHARED by all workers) ────────────────
# The loop polls the account's rolling windows (5-hour session + 7-day week — the same numbers
# Claude Code's /usage shows) via the OAuth usage endpoint, and paces the fleet:
#   >= USAGE_PAUSE_PCT on the 5h window  -> DRAIN: in-flight slices finish and land, nothing
#                                           new is planned/assigned
#   all drained (or hard-limited at 100%) -> PAUSE: sleep until the window resets, then fire
#                                           the resume trigger (PROGRESS event + notification +
#                                           a nudge into every in-flight worker)
# The endpoint is undocumented (it may change); the guard is FAIL-OPEN — if the probe breaks,
# the loop behaves as if the guard were off. Probe cadence respects the endpoint's own rate
# limiting (>=180s; cached in state/usage.cache). 1=on.
USAGE_GUARD=1
USAGE_PAUSE_PCT=80
# The 7-day window can also drain/pause the loop (resuming may then take days — you get a
# notification). Set to 100 to only react when the week is fully exhausted.
USAGE_WEEKLY_PAUSE_PCT=95
# Seconds between live probes / extra margin after the reported reset before resuming.
USAGE_POLL_SECS=300
USAGE_RESUME_MARGIN_SECS=90
# Override the probe entirely (tests / API-key billing / custom monitors). Must print
# "<5h_pct> <5h_reset_epoch> <7d_pct> <7d_reset_epoch>" or "none".
USAGE_PROBE_CMD=

# Worker liveness watchdog. A hung / spinning / never-committing worker changes no ref, so
# without this it would pin a slice forever and the loop would never complete. After
# WORKER_TIMEOUT_SECS with NO progress (no new commit AND the agent not 'working'), the loop
# nudges the worker; if still stalled WORKER_HANG_GRACE seconds later it auto-respawns the worker
# (keeps the assignment, discards only un-committed scratch) and burns a feedback round — so a
# chronically-stalling slice eventually ESCALATES to a human. 0 = watchdog off. Tune to slice size.
WORKER_TIMEOUT_SECS=1800
WORKER_HANG_GRACE=300

# Planner (DISCOVER/PLAN). The planner is a HEADLESS, throwaway Claude run in a disposable
# detached worktree that reads skills/ + memory/ and decomposes the next backlog goal into
# vertical slices + thin contract tests. Set to 0 to run the loop with human-written slices only:
# write memory/slices/<goal-slug>.json (goal-scoped, preferred) or memory/slices/current.json —
# the loop archives the file (*.consumed-<utc>) once read, so the NEXT goal never reuses it.
PLANNER_ENABLED=1
# Max slices the planner may emit per goal (= max workers it can fan a single goal across).
PLANNER_MAX_SLICES=3

# ─── Codex second opinion (independent cross-architecture review) ────────────────────────────
# A DIFFERENT model (OpenAI codex CLI) independently reviews (a) each plan and (b) each gated
# diff — artifacts only, never Claude's reasoning — so blind spots of one architecture get a
# second pair of eyes.  off = never run | advise = non-blocking (default; high-severity gate
# concerns consume ONE bounded feedback round) | block = concerns stop the plan / the land.
# codex absent? Everything auto-skips with a CODEX_SKIP event — the loop never stalls on it.
SECOND_OPINION=advise
# Per-phase overrides (empty = inherit SECOND_OPINION): plan critique / gate review.
SECOND_OPINION_PLAN=
SECOND_OPINION_GATE=
# Model for `codex exec` (empty = codex default), and a hard timeout per review.
CODEX_MODEL=
CODEX_TIMEOUT=300
# advise mode: how many feedback rounds per slice codex-only HIGH concerns may consume (they
# also count toward MAX_FEEDBACK_ROUNDS, so the worst case stays bounded and escalates).
CODEX_GATE_MAX_ROUNDS=1
# Cap on the diff embedded into the gate-review prompt (head+tail, middle elided).
CODEX_DIFF_MAX_LINES=4000

# Desktop/terminal notifications on loop events (commit/gate/land/escalate). 1=on.
# Uses herdr notifications + terminal bell; on WSL2 also wsl-notify-send if installed.
NOTIFY=1

# ─── Context hygiene (what the loop feeds into LLM contexts) ───────────────────────────────
# memory/PROGRESS.md is read WHOLE by the planner every cycle. Past PROGRESS_MAX_LINES it is
# compacted: events older than the last PROGRESS_KEEP_LINES are folded into one count line
# (ESCALATED / LAND_FAIL entries are always kept verbatim — they are unresolved work).
PROGRESS_MAX_LINES=400
PROGRESS_KEEP_LINES=200
# Cap the gate log routed into a worker's feedback.md (head+tail, middle elided) so a long
# `npm ci` transcript doesn't bury the actual test failure in the worker's context.
FEEDBACK_MAX_LINES=200
# Scoped "LLM wiki" (token-cheap variant): each slice owns wiki/modules/<slice>.md and the
# worker updates it as part of DONE (it already holds the full context — the cheap moment to
# write it down). The planner reads wiki/index.md + relevant pages BEFORE exploring code, and
# index.md is regenerated by script on every land (0 tokens, 0 conflicts). Planner token usage
# is logged per goal to memory/PROGRESS.md as PLAN_USAGE — compare with 0 vs 1 and decide on
# data. 0 = off (no wiki instructions anywhere).
WIKI_ENABLED=1
# AIF-style event ontology (memory/ontology/graph.jsonl + digest.md): CA/PA nodes appended by
# the HOST from loop events only (gate FAIL / codex concerns -> CA, land / handoff -> PA) —
# never hand- or LLM-maintained, so it cannot rot. The planner reads the digest's "open
# conflicts" (CA newer than the target's last PA) to avoid re-planning into known failures.
# Validate with `loop ontology-check`. 0 = no ontology writes/reads anywhere.
ONTOLOGY_ENABLED=1
# Design SSOT direct-read: absolute path to a typed-design tree the PLANNER reads directly
# every cycle (e.g. /path/to/design-repo/atlas for a Spec Atlas project — Domain/=vocabulary,
# Spec/=design data; the LLM reads the sources, no exported bundle involved). Its entities,
# ports and IO contracts are treated as authoritative over any implementation choice.
# Empty = auto-detect atlas/ inside the repo when present.
DESIGN_SSOT_DIR=
