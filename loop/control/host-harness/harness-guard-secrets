#!/usr/bin/env bash
# Host-side secret guard (defense-in-depth for goal #3). The PRIMARY concealment is structural:
# no Claude runs on the host in the autonomous design — only deterministic shell does. This hook
# is the SECOND layer for the optional case where a human keeps an interactive supervisor Claude
# open on the host: it blocks the obvious ways that Claude could read the disposable worker key
# or other secrets. It is best-effort (a determined agent has many side channels) — the real
# boundary remains "credentials never enter a Claude-readable process".
#
# Wire it as a PreToolUse hook for Bash AND Read|Edit|Write (see host-harness/settings.json).
# Exit 2 blocks the tool and shows stderr to Claude.
input="$(cat)"
cmd="$(printf '%s'  "$input" | jq -r '.tool_input.command // empty' 2>/dev/null)"
path="$(printf '%s' "$input" | jq -r '.tool_input.file_path // .tool_input.path // .tool_input.notebook_path // empty' 2>/dev/null)"

deny() { echo "HOST-GUARD: $1" >&2; exit 2; }

# 1) Any direct file access (Read/Edit/Write) to the secret file.
if [ -n "$path" ]; then
  case "$path" in
    *secret.env) deny "accessing secret.env is blocked — the disposable worker key must stay out of the model's context." ;;
  esac
fi

# 2) Bash commands that would exfiltrate the key or dump the environment.
if [ -n "$cmd" ]; then
  if echo "$cmd" | grep -qiE 'secret\.env'; then
    deny "touching secret.env via the shell is blocked (worker key stays concealed)."
  fi
  if echo "$cmd" | grep -qE '\b(env|printenv|set)\b' && echo "$cmd" | grep -qiE 'ANTHROPIC|API_KEY|secret'; then
    deny "dumping environment variables that may contain credentials is blocked."
  fi
  if echo "$cmd" | grep -qiE 'ANTHROPIC_API_KEY'; then
    deny "referencing ANTHROPIC_API_KEY is blocked on the host."
  fi
  if echo "$cmd" | grep -qiE 'docker[[:space:]]+inspect'; then
    deny "docker inspect can reveal a container's env (the key) — blocked. Ask a human if you need container details."
  fi
fi
exit 0
