# Copy to `secret.gate.env` (gitignored; chmod 600). KEY=VALUE per line. These are injected ONLY
# into the GATE container (which runs your tests/checks — NOT Claude), so the acceptance suite can
# use secrets the worker Claude must never see. Prefer disposable / test-scoped values.
#
# Examples (replace with yours):
# DATABASE_URL=postgres://test:test@db.test.local:5432/app_test
# STRIPE_TEST_KEY=sk_test_xxxxxxxx
# TEST_API_TOKEN=xxxxxxxx
