#!/usr/bin/env bash
# `loop` — thin CLI over the centrally-installed engine. Install once, use from any project:
#
#   git clone <this-repo> ~/.loop/loop-template
#   ln -s ~/.loop/loop-template/loop/bin/loop ~/.local/bin/loop
#
#   loop here                    attach the CURRENT project, zero-footprint: the workspace
#                                lives under $LOOP_HOME/workspaces/<path-slug>, the project
#                                repo itself gets NO files (its git history stays clean)
#   loop publish                 deliver landed work to the project as branch loop/<base>
#   loop refresh                 absorb the project's new commits into the loop's base
#   loop workspaces              list every attached project and its fleet
#   loop init <dir> [repo-url]   create a standalone workspace directory instead of attaching
#   loop secrets <sub>           manage sops-encrypted secrets: init | edit <scope> | status |
#                                migrate --yes   (scopes: worker / gate / codex)
#   loop supervise               interactive supervision: YOU + a strong Claude (SUPERVISOR_MODEL)
#                                assign/verify/land in dialogue; cheap workers (WORKER_MODEL)
#                                implement in parallel; watch.sh auto-gates every commit burst
#   loop update / loop version   update the engine (applies to every workspace) / show version
#   loop <cmd> [args...]         any control/<cmd>.sh: up, down, run (=loop.sh), dashboard,
#                                status, doctor, setup, plan, verify, land, spawn, assign, ...
#
# Workspace resolution (control/lib.sh): $LOOP_PROJECT, else a `.loop-workspace` marker in an
# ancestor of $PWD, else the central workspace for the enclosing git project, else legacy.
set -euo pipefail

SELF="${BASH_SOURCE[0]}"
[ -L "$SELF" ] && SELF="$(readlink -f "$SELF")"
ENGINE="$(cd "$(dirname "$SELF")/.." && pwd)"
CTL="$ENGINE/control"

usage() {
  sed -n '2,25p' "$SELF" | sed 's/^# \{0,1\}//'
  echo
  echo "engine: $ENGINE (v$(cat "$ENGINE/VERSION" 2>/dev/null || echo '?'))"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  help|--help|-h) usage; exit 0 ;;
  version|--version|-v)
    echo "loop engine v$(cat "$ENGINE/VERSION" 2>/dev/null || echo '?') at $ENGINE"
    git -C "$ENGINE" log -1 --format='  commit %h (%ci)' 2>/dev/null || true
    exit 0 ;;
  update)
    echo "loop: updating engine at $ENGINE ..."
    git -C "$ENGINE" pull --ff-only
    echo "loop: engine now v$(cat "$ENGINE/VERSION" 2>/dev/null || echo '?'). All workspaces pick this up on their next command."
    exit 0 ;;
  init)  exec "$CTL/init.sh" "$@" ;;
  run)   exec "$CTL/loop.sh" "$@" ;;   # `loop run` reads better than `loop loop`
  *)
    if [ -f "$CTL/$cmd.sh" ]; then exec bash "$CTL/$cmd.sh" "$@"; fi
    echo "loop: unknown command '$cmd'" >&2; echo >&2; usage >&2; exit 1 ;;
esac
