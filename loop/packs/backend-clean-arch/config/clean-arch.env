# backend-clean-arch pack configuration (sourced by the L2 guard and the L3 gate check).
# Until CORE_DIRS is set, both are advisory no-ops — configure them for YOUR project.

# Space-separated repo-relative path prefixes that form the CORE (domain vocabulary, entities,
# use cases). Example: "src/domain/ src/usecases/"
CORE_DIRS=""

# ERE matched against lines ADDED to core files; a match is an outward (forbidden) dependency.
# Example (TS backend): "from ['\"](express|fastify|pg|prisma|axios|\.\./(infra|adapters))"
FORBIDDEN_IMPORT_REGEX=""
