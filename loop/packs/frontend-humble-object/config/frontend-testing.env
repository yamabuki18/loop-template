# frontend-humble-object pack configuration (sourced by the L2 guard and L3 gate check).
# ERE matched against repo-relative paths a worker creates/edits; a match = E2E-suite artifact.
E2E_BLOCK_REGEX='(^|/)(e2e|cypress)(/|$)|\.(e2e|cy)\.[A-Za-z]+(\.[A-Za-z]+)?$|(^|/)playwright\.config\.'
# ERE for Bash commands that run an E2E runner (workers never run suites; the gate does).
E2E_RUN_REGEX='(^|[;&| ])(npx +)?(playwright +test|cypress +(run|open))'
